# Copy this file to .env and fill in the paths for your local toolchain installation.
# .env is gitignored — never commit it.
# These variables are read by .vscode/launch.json for cortex-debug configurations.

# Full path to the openocd executable
OPENOCD_PATH=

# Full path to arm-none-eabi-gdb executable
GDB_PATH=

# Directory containing the arm-none-eabi-* binaries (used by cortex-debug armToolchainPath)
ARM_TOOLCHAIN_PATH=

# Full path to arm-none-eabi-objdump executable
OBJDUMP_PATH=

# Source path prefix used by GDB's substitute-path (usually the workspace root,
# but may differ if the build runs in a container or WSL path)
BUILD_SOURCE_PATH=

# Full path to arm-none-eabi-gcc — add to clangd.arguments as:
#   --query-driver=<CLANGD_QUERY_DRIVER>
# See .vscode/settings.json for context.
CLANGD_QUERY_DRIVER=
