{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug CM7 (OpenOCD)",
            "type": "cortex-debug",
            "request": "launch",
            "servertype": "openocd",
            "serverpath": "${env:OPENOCD_PATH}",
            "cwd": "${workspaceFolder}",
            "executable": "${workspaceFolder}/build/CM7/cube_CM7.elf",
            "configFiles": [
                "${workspaceFolder}/tools/openocd/openocd.cfg"
            ],
            "gdbPath": "${env:GDB_PATH}",
            "armToolchainPath": "${env:ARM_TOOLCHAIN_PATH}",
            "toolchainPrefix": "arm-none-eabi",
            "objdumpPath": "${env:OBJDUMP_PATH}",
            "device": "STM32H745XI",
            "svdFile": "",
            "numberOfProcessors": 2,
            "targetProcessor": 0,
            "preLaunchTask": "Build",
            "preLaunchCommands": [
                "set substitute-path ${env:BUILD_SOURCE_PATH} ${workspaceFolder}"
            ],
            "showDevDebugOutput": "raw",
        },
        {
            "name": "Debug CM4 (OpenOCD)",
            "type": "cortex-debug",
            "request": "attach",
            "servertype": "external",
            "cwd": "${workspaceFolder}",
            "executable": "${workspaceFolder}/build/CM4/cube_CM4.elf",
            "gdbTarget": "localhost:50001",
            "gdbPath": "${env:GDB_PATH}",
            "armToolchainPath": "${env:ARM_TOOLCHAIN_PATH}",
            "toolchainPrefix": "arm-none-eabi",
            "objdumpPath": "${env:OBJDUMP_PATH}",
            "device": "STM32H745XI",
            "svdFile": "",
            "numberOfProcessors": 2,
            "targetProcessor": 1,
            "preAttachCommands": [
                "set substitute-path ${env:BUILD_SOURCE_PATH} ${workspaceFolder}"
            ],
            "showDevDebugOutput": "raw",
        },
        {
            "name": "Debug CM4 (OpenOCD, Standalone)",
            "type": "cortex-debug",
            "request": "launch",
            "servertype": "openocd",
            "serverpath": "${env:OPENOCD_PATH}",
            "cwd": "${workspaceFolder}",
            "executable": "${workspaceFolder}/build/CM4/cube_CM4.elf",
            "configFiles": [
                "${workspaceFolder}/tools/openocd/openocd.cfg"
            ],
            "gdbPath": "${env:GDB_PATH}",
            "armToolchainPath": "${env:ARM_TOOLCHAIN_PATH}",
            "toolchainPrefix": "arm-none-eabi",
            "objdumpPath": "${env:OBJDUMP_PATH}",
            "device": "STM32H745XI",
            "svdFile": "",
            "numberOfProcessors": 2,
            "targetProcessor": 1,
            "preLaunchTask": "Build",
            "preLaunchCommands": [
                "set substitute-path ${env:BUILD_SOURCE_PATH} ${workspaceFolder}"
            ],
            "showDevDebugOutput": "raw",
        },
        {
            "name": "Attach CM7 (OpenOCD)",
            "type": "cortex-debug",
            "request": "attach",
            "servertype": "openocd",
            "serverpath": "${env:OPENOCD_PATH}",
            "cwd": "${workspaceFolder}",
            "executable": "${workspaceFolder}/build/CM7/cube_CM7.elf",
            "configFiles": [
                "${workspaceFolder}/tools/openocd/openocd.cfg"
            ],
            "gdbPath": "${env:GDB_PATH}",
            "armToolchainPath": "${env:ARM_TOOLCHAIN_PATH}",
            "toolchainPrefix": "arm-none-eabi",
            "objdumpPath": "${env:OBJDUMP_PATH}",
            "device": "STM32H745XI",
            "svdFile": "",
            "numberOfProcessors": 2,
            "targetProcessor": 0,
            "preAttachCommands": [
                "set substitute-path ${env:BUILD_SOURCE_PATH} ${workspaceFolder}"
            ],
            "showDevDebugOutput": "raw",
        }
    ],
    "compounds": [
        {
            "name": "Debug Dual-Core (CM7 + CM4)",
            "configurations": [
                "Debug CM7 (OpenOCD)",
                "Debug CM4 (OpenOCD)"
            ],
            "stopAll": true
        }
    ]
}
