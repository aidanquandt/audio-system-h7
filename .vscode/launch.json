{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug CM7 (OpenOCD)",
            "type": "cortex-debug",
            "request": "launch",
            "servertype": "openocd",
            "serverpath": "/usr/bin/openocd",
            "cwd": "${workspaceFolder}",
            "executable": "${workspaceFolder}/build/CM7/stm32_hw_CM7.elf",
            "configFiles": [
                "${workspaceFolder}/tools/openocd/openocd.cfg"
            ],
            "gdbPath": "/usr/bin/gdb-multiarch",
            "armToolchainPath": "/usr/bin",
            "toolchainPrefix": "arm-none-eabi",
            "objdumpPath": "/usr/bin/arm-none-eabi-objdump",
            "device": "STM32H745XI",
            "svdFile": "",
            "numberOfProcessors": 2,
            "targetProcessor": 0,
            "preLaunchTask": "Prepare Debug",
            "showDevDebugOutput": "raw"
        },
        {
            "name": "Debug CM4 (OpenOCD)",
            "type": "cortex-debug",
            "request": "attach",
            "servertype": "external",
            "preLaunchTask": "Attach USB",
            "cwd": "${workspaceFolder}",
            "executable": "${workspaceFolder}/build/CM4/stm32_hw_CM4.elf",
            "gdbTarget": "localhost:50001",
            "gdbPath": "/usr/bin/gdb-multiarch",
            "armToolchainPath": "/usr/bin",
            "toolchainPrefix": "arm-none-eabi",
            "objdumpPath": "/usr/bin/arm-none-eabi-objdump",
            "device": "STM32H745XI",
            "svdFile": "",
            "numberOfProcessors": 2,
            "targetProcessor": 1,
            "showDevDebugOutput": "raw"
        },
        {
            "name": "Debug CM4 (OpenOCD, Standalone)",
            "type": "cortex-debug",
            "request": "launch",
            "servertype": "openocd",
            "serverpath": "/usr/bin/openocd",
            "cwd": "${workspaceFolder}",
            "executable": "${workspaceFolder}/build/CM4/stm32_hw_CM4.elf",
            "configFiles": [
                "${workspaceFolder}/tools/openocd/openocd.cfg"
            ],
            "gdbPath": "/usr/bin/gdb-multiarch",
            "armToolchainPath": "/usr/bin",
            "toolchainPrefix": "arm-none-eabi",
            "objdumpPath": "/usr/bin/arm-none-eabi-objdump",
            "device": "STM32H745XI",
            "svdFile": "",
            "numberOfProcessors": 2,
            "targetProcessor": 1,
            "preLaunchTask": "Prepare Debug",
            "showDevDebugOutput": "raw"
        },
        {
            "name": "Attach CM7 (OpenOCD)",
            "type": "cortex-debug",
            "request": "attach",
            "servertype": "openocd",
            "preLaunchTask": "Attach USB",
            "serverpath": "/usr/bin/openocd",
            "cwd": "${workspaceFolder}",
            "executable": "${workspaceFolder}/build/CM7/stm32_hw_CM7.elf",
            "configFiles": [
                "${workspaceFolder}/tools/openocd/openocd.cfg"
            ],
            "gdbPath": "/usr/bin/gdb-multiarch",
            "armToolchainPath": "/usr/bin",
            "toolchainPrefix": "arm-none-eabi",
            "objdumpPath": "/usr/bin/arm-none-eabi-objdump",
            "device": "STM32H745XI",
            "svdFile": "",
            "numberOfProcessors": 2,
            "targetProcessor": 0,
            "showDevDebugOutput": "raw"
        }
    ],
    "compounds": [
        {
            "name": "Debug Dual-Core (CM7 + CM4)",
            "configurations": [
                "Debug CM7 (OpenOCD)",
                "Debug CM4 (OpenOCD)"
            ],
            "stopAll": true
        }
    ]
}
